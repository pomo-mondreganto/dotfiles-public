alias copy="it2copy"
alias kaf="kubectl apply -f"
alias pg="pgcli"
alias reload="source ~/.zshrc"
alias gsave="git add . && git commit -m 'save'"

# History size overrides. OMZ's lib/history.zsh sets these only if smaller
# (see its [-z]/[-lt] checks), so writing larger values here wins. Loaded
# AFTER sheldon's omz-lib-history, which sets the setopts (EXTENDED_HISTORY,
# SHARE_HISTORY, HIST_*).
HISTFILE="$HOME/.zsh_history"
HISTSIZE=1000000
SAVEHIST=1000000

# Colorize ls and grep. OMZ's lib/theme-and-appearance.zsh would do this
# with a fork-based runtime probe; this is OS-branched at chezmoi-template
# time, no fork.
{{ if eq .chezmoi.os "darwin" -}}
alias ls='ls -G'
export LSCOLORS="Gxfxcxdxbxegedabagacad"
{{- else -}}
alias ls='ls --color=auto'
{{- end }}
alias grep='grep --color=auto --exclude-dir={.bzr,CVS,.git,.hg,.svn,.idea,.tox,.venv,venv,node_modules,__pycache__}'
alias egrep='grep -E'
alias fgrep='grep -F'

# fzf Ctrl+R / Ctrl+T / Alt+C key bindings and completion integration.
(( ${+commands[fzf]} )) && zcache fzf 'fzf --zsh' ${commands[fzf]}

{{ if eq .chezmoi.os "darwin" }}
# Cache `brew shellenv` output; invalidate only when brew binary changes.
zcache brew-shellenv '/opt/homebrew/bin/brew shellenv' /opt/homebrew/bin/brew

export BREW_PREFIX="$(brew --prefix)"
export FPATH="${BREW_PREFIX}/share/zsh/site-functions:${FPATH}"

alias code="/Applications/Visual\ Studio\ Code.app/Contents/MacOS/Electron"

# brew install
function bip() {
  local inst=`brew search "$@" | fzf -m`

  if [[ $inst ]]; then
    for prog in `echo $inst`;
    do; brew install $prog; done;
  fi
}

# brew update
function bup() {
  local upd=`brew leaves | fzf -m`

  if [[ $upd ]]; then
    for prog in `echo $upd`;
    do; brew upgrade $prog; done;
  fi
}

function fdns() {
  sudo dscacheutil -flushcache; sudo killall -HUP mDNSResponder
}
{{- end }}

export CARGO_UNSTABLE_SPARSE_REGISTRY=true

# fshow - git commit browser
function fshow() {
  git log --graph --color=always \
      --format="%C(auto)%h%d %s %C(black)%C(bold)%cr" "$@" |
  fzf --ansi --no-sort --reverse --tiebreak=index --bind=ctrl-s:toggle-sort \
      --bind "ctrl-m:execute:
                (grep -o '[a-f0-9]\{7\}' | head -1 |
                xargs -I % sh -c 'git show --color=always % | less -R') << 'FZF-EOF'
                {}
FZF-EOF"
}

function gnb {
  git fetch
  git switch -c "rnikitin/$1" origin/master
  git branch --unset-upstream
}

function gnbb {
  git fetch
  git switch -c "pomo/$1" origin/master
  git branch --unset-upstream
}

function gcb {
  git checkout $(git branch --sort=-committerdate $@ | fzf)
}

gnw () {
  local name="${1:?Usage: gnw <name> [repo] [dir]}"
  local repo="${2:-$HOME/repos/dm}"
  local dir="${3:-$HOME/work/$name}"
  local branch="rnikitin/$name"

  (cd "$repo" && git fetch origin) || { echo "fetch failed"; return 1; }

  git -C "$repo" worktree add -b "$branch" "$dir" origin/master || { echo "worktree add failed"; return 1; }

  # Keep behavior consistent with gnb: no upstream right after creation.
  git -C "$dir" branch --unset-upstream >/dev/null 2>&1 || true

  echo "Worktree: $dir"
  echo "Branch:   $branch"
  echo "To create remote + set tracking:"
  echo "  (cd \"$dir\" && git push -u origin \"$branch\")"
}
