# Enable Powerlevel10k instant prompt. Should stay close to the top of ~/.zshrc.
# Initialization code that may require console input (password prompts, [y/n]
# confirmations, etc.) must go above this block; everything else may go below.
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

# Autoloads + keymap previously provided by the OMZ base lib. Must happen
# before sheldon sources fzf / fzf-tab so their bindings land in the emacs
# keymap rather than being orphaned in vi's.
autoload -Uz colors && colors
autoload -Uz is-at-least
bindkey -e

# mise shims must be on PATH before the plugin manager runs (sheldon is
# installed via `mise use -g aqua:rossmacarthur/sheldon`).
export PATH="$HOME/.local/share/mise/shims:$HOME/.local/bin:/usr/local/go/bin:$PATH"

# zcache: cached `eval "$(cmd)"` helper (replacement for znap eval).
# Defines the `zcache` function; see ~/.shell/eval-cache.zsh for usage.
test -e "$HOME/.shell/eval-cache.zsh" && source "$HOME/.shell/eval-cache.zsh"

# mise shell integration: gives us mise's chpwd/precmd hooks and its
# `command_not_found_handler` (auto-install from .mise.toml). The cache
# is invalidated whenever the mise binary is upgraded.
(( ${+commands[mise]} )) && zcache mise-activate 'mise activate zsh' ${commands[mise]}

# Plugin manager: sheldon. We cache `sheldon source`'s output to a plain
# zsh script and only regenerate it when ~/.config/sheldon/plugins.toml
# is newer. Steady-state startup then avoids forking the sheldon binary.
_sheldon_conf="${XDG_CONFIG_HOME:-$HOME/.config}/sheldon/plugins.toml"
_sheldon_cache="${XDG_CACHE_HOME:-$HOME/.cache}/sheldon.zsh"
if (( ${+commands[sheldon]} )); then
  if [[ ! -s $_sheldon_cache || $_sheldon_conf -nt $_sheldon_cache ]]; then
    mkdir -p -- ${_sheldon_cache:h}
    sheldon source 2>/dev/null >| $_sheldon_cache
  fi
  source $_sheldon_cache
fi
unset _sheldon_conf _sheldon_cache

# User configuration.

export LANG=en_US.UTF-8
export EDITOR="vim"

alias zshconfig="$EDITOR ~/.zshrc"

# GOBIN comes from mise; fall back to Go's default if unset.
export PATH="${GOBIN:-$HOME/go/bin}:$PATH"

test -e "$HOME/.shell/common.zsh" && source "$HOME/.shell/common.zsh"
test -e "$HOME/.shell/local.zsh" && source "$HOME/.shell/local.zsh"

# To customize prompt, run `p10k configure` or edit ~/.p10k.zsh.
[[ ! -f ~/.p10k.zsh ]] || source ~/.p10k.zsh

# bun
[ -s "$HOME/.bun/_bun" ] && source "$HOME/.bun/_bun"
export BUN_INSTALL="$HOME/.bun"
export PATH="$BUN_INSTALL/bin:$PATH"
